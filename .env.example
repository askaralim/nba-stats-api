# Server Configuration
PORT=3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# PostgreSQL (optional; app runs without DB if unset)
# Same instance for test/dev and production is fine.
#
# Local / test / dev:
#   - Copy DATABASE_URL from Railway Postgres (Variables tab → DATABASE_URL).
#   - Or set individual vars: PGHOST, PGPORT, PGUSER, PGPASSWORD, PGDATABASE
# DATABASE_URL=postgresql://user:password@host:5432/railway
#
# Production (Railway):
#   - In your nba-stats-api service: Variables → "Add Variable Reference".
#   - Select your Postgres service and pick DATABASE_URL (or use PG* vars).
#   - This links the DB to the API so DATABASE_URL is set in production.
# -----------------------------------------------------------------------------

# CORS Configuration
# For local development, use http://localhost:5173 (Vite default port)
# For production, use your frontend URL (e.g., https://your-app.vercel.app)
CORS_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# News v2 (optional - feature works without these; uses defaults)
# NEWS_TRANSLATION_BATCH_SIZE=5
# NEWS_TRANSLATION_DELAY_MS=1000
# NEWS_RETENTION_DAYS=30
# -----------------------------------------------------------------------------

# OpenAI (required for News v2 translation)
# OPENAI_API_KEY=your-key
# OPENAI_BASE_URL=https://openai.api2d.net/v1
# GPT_MODEL=gpt-3.5-turbo